{
  "name": "@ariel-salgado/vite-plugin-file-router",
  "type": "module",
  "version": "0.0.1",
  "description": "Vite plugin that auto-discovers HTML pages in a directory",
  "author": "Ariel Salgado <ariel.salgado.acevedo@gmail.com> (https://github.com/ariel-salgado/)",
  "license": "MIT",
  "homepage": "https://github.com/ariel-salgado/vite-plugins/tree/main/packages/vite-plugin-file-router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariel-salgado/vite-plugins.git",
    "directory": "packages/vite-plugin-file-router"
  },
  "keywords": [
    "vite",
    "plugin",
    "mpa",
    "html",
    "pages",
    "multi-page",
    "file-router"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0-0"
  },
  "dependencies": {
    "picomatch": "4.0.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/picomatch": "4.0.2",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  }
}
